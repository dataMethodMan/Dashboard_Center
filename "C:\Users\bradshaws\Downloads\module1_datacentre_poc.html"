<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Module 1 Data Centre Interactive PoC</title>
<style>
:root{--bg:#07111f;--panel:#0e1f36;--panel2:#132b48;--line:#244a6d;--text:#eaf6ff;--muted:#9bb8d4;--cyan:#22d3ee;--blue:#60a5fa;--ok:#36d399;--warn:#fbbf24;--bad:#fb7185;--purple:#a78bfa}
*{box-sizing:border-box} body{margin:0;font-family:Inter,Segoe UI,Arial,sans-serif;background:radial-gradient(circle at 20% 0,#12365d,#07111f 55%,#030712);color:var(--text);overflow-x:hidden}
.wrap{max-width:1180px;margin:0 auto;padding:14px}.hero{display:flex;align-items:center;justify-content:space-between;gap:14px;margin-bottom:12px}.title h1{font-size:24px;margin:0 0 4px}.title p{margin:0;color:var(--muted);font-size:14px}.pill{border:1px solid var(--line);padding:7px 10px;border-radius:999px;color:var(--muted);font-size:13px;white-space:nowrap}.tabs{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:12px}.tab{background:#102947;color:var(--text);border:1px solid #285272;border-radius:999px;padding:9px 13px;cursor:pointer;font-weight:800}.tab.active{background:#0e7490;border-color:var(--cyan);box-shadow:0 0 18px rgba(34,211,238,.25)}
.grid{display:grid;grid-template-columns:1.25fr .75fr;gap:12px}.panel{background:linear-gradient(180deg,rgba(17,36,61,.95),rgba(8,21,38,.96));border:1px solid #183a5b;border-radius:18px;box-shadow:0 18px 50px rgba(0,0,0,.24);padding:14px}.panel h2{font-size:17px;margin:0 0 8px}.panel p{color:var(--muted);font-size:14px;line-height:1.45;margin:0 0 10px}.controls{display:flex;gap:8px;flex-wrap:wrap}.btn{background:#122c49;color:var(--text);border:1px solid #295274;border-radius:12px;padding:10px 12px;cursor:pointer;font-weight:800}.btn:hover{border-color:var(--cyan)}.btn.primary{background:#0e7490;border-color:#22d3ee}.note{background:#08172a;border:1px solid #1f3a57;border-radius:14px;padding:12px;min-height:95px}.note b{color:#fff}.kpis{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin-top:10px}.kpi{background:#08172a;border:1px solid #1f3a57;border-radius:14px;padding:10px}.kpi .label{font-size:11px;text-transform:uppercase;letter-spacing:.12em;color:var(--muted)}.kpi .value{font-size:22px;font-weight:900;margin-top:3px}.kpi.ok .value{color:var(--ok)}.kpi.warn .value{color:var(--warn)}.kpi.blue .value{color:var(--cyan)}
.scene{width:100%;height:430px;background:#06101e;border:1px solid #1f3a57;border-radius:16px;display:block}.smallscene{width:100%;height:250px;background:#06101e;border:1px solid #1f3a57;border-radius:16px;display:block}.hotspot{cursor:pointer}.hotspot:hover .room{stroke:var(--cyan);stroke-width:3}.room{fill:#102947;stroke:#2c5b7d;stroke-width:2}.room.active{fill:#164e63;stroke:#22d3ee;filter:drop-shadow(0 0 8px rgba(34,211,238,.8))}.labelsvg{font:700 15px Segoe UI,Arial;fill:#eaf6ff}.mutedsvg{font:12px Segoe UI,Arial;fill:#9bb8d4}.packet{filter:drop-shadow(0 0 10px #22d3ee);opacity:0}.systemGlow{opacity:.25}.systemGlow.on{opacity:1;filter:drop-shadow(0 0 10px currentColor)}.pathline{stroke:#274b68;stroke-width:5;fill:none;stroke-linecap:round}.activePath{stroke:#22d3ee;stroke-width:4;fill:none;stroke-linecap:round;stroke-dasharray:10 12;animation:dash 1s linear infinite}@keyframes dash{to{stroke-dashoffset:-44}}.pulse{animation:pulse 1.5s ease-in-out infinite}@keyframes pulse{50%{opacity:.35;transform:scale(1.05)}}
.dayGrid{display:grid;grid-template-columns:repeat(2,1fr);gap:8px}.day{background:#08172a;border:1px solid #1f3a57;border-radius:12px;padding:10px;cursor:pointer}.day:hover,.day.active{border-color:var(--cyan);background:#0d2748}.day b{display:block;font-size:14px}.day span{color:var(--muted);font-size:12px}.footer{color:var(--muted);font-size:12px;margin-top:8px;text-align:center}
@media(max-width:900px){.grid{grid-template-columns:1fr}.kpis{grid-template-columns:repeat(2,1fr)}.scene{height:390px}.dayGrid{grid-template-columns:1fr}.hero{align-items:flex-start;flex-direction:column}}
</style>
</head>
<body>
<div class="wrap">
  <div class="hero"><div class="title"><h1>The Digital World Has a Physical Home</h1><p>Interactive SVG PoC for Module 1: reveal how everyday digital actions depend on real data centre systems.</p></div><div class="pill">Module 1 · Data Centre Foundations</div></div>
  <div class="tabs"><button class="tab active" onclick="showView('send',this)">1. Tap Send Journey</button><button class="tab" onclick="showView('day',this)">2. Your Digital Day</button><button class="tab" onclick="showView('tour',this)">3. Explore the Facility</button><button class="tab" onclick="showView('systems',this)">4. Systems Working Together</button></div>

  <section id="send" class="view grid">
    <div class="panel"><h2>Tap Send Journey</h2><p>Click send and watch a photo travel from a phone to a real data centre, where power, cooling, networking, security, and operations all support the moment.</p><svg class="scene" viewBox="0 0 900 430" aria-label="Animated journey from phone to data centre to friend">
      <defs><linearGradient id="building" x1="0" x2="1"><stop stop-color="#102947"/><stop offset="1" stop-color="#17395f"/></linearGradient></defs>
      <path class="pathline" d="M125,218 C260,90 360,130 448,215 S650,350 778,210"/>
      <path id="journeyPath" class="activePath" d="M125,218 C260,90 360,130 448,215 S650,350 778,210"/>
      <g transform="translate(55 135)"><rect x="0" y="0" width="95" height="165" rx="18" fill="#0a1628" stroke="#2c5b7d" stroke-width="3"/><rect x="12" y="22" width="71" height="105" rx="8" fill="#12365d"/><circle cx="48" cy="145" r="7" fill="#284b68"/><text x="47" y="70" text-anchor="middle" class="labelsvg">YOU</text><text x="47" y="92" text-anchor="middle" class="mutedsvg">tap send</text></g>
      <g transform="translate(360 105)"><rect x="0" y="82" width="190" height="130" rx="8" fill="url(#building)" stroke="#2c5b7d" stroke-width="3"/><polygon points="-10,82 95,20 200,82" fill="#0e2038" stroke="#2c5b7d" stroke-width="3"/><text x="95" y="72" text-anchor="middle" class="labelsvg">DATA CENTRE</text><rect x="25" y="112" width="25" height="70" fill="#07111f"/><rect x="60" y="112" width="25" height="70" fill="#07111f"/><rect x="105" y="112" width="25" height="70" fill="#07111f"/><rect x="140" y="112" width="25" height="70" fill="#07111f"/><text x="95" y="202" text-anchor="middle" class="mutedsvg">physical home of the digital world</text></g>
      <g transform="translate(760 135)"><rect x="0" y="0" width="95" height="165" rx="18" fill="#0a1628" stroke="#2c5b7d" stroke-width="3"/><rect x="12" y="22" width="71" height="105" rx="8" fill="#12365d"/><text x="47" y="72" text-anchor="middle" class="labelsvg">FRIEND</text><text x="47" y="94" text-anchor="middle" class="mutedsvg">receives it</text></g>
      <g id="packet" class="packet"><circle r="12" fill="#22d3ee"/><text x="0" y="4" text-anchor="middle" font-size="14">📷</text></g>
      <g transform="translate(270 320)" class="systemGlow" id="sgPower" style="color:#fbbf24"><circle r="28" fill="#18122f" stroke="#fbbf24"/><text text-anchor="middle" y="5" font-size="24">⚡</text><text text-anchor="middle" y="50" class="mutedsvg">Power</text></g>
      <g transform="translate(385 335)" class="systemGlow" id="sgCool" style="color:#60a5fa"><circle r="28" fill="#0b1f33" stroke="#60a5fa"/><text text-anchor="middle" y="5" font-size="24">❄</text><text text-anchor="middle" y="50" class="mutedsvg">Cooling</text></g>
      <g transform="translate(505 335)" class="systemGlow" id="sgNet" style="color:#22d3ee"><circle r="28" fill="#092533" stroke="#22d3ee"/><text text-anchor="middle" y="5" font-size="24">🌐</text><text text-anchor="middle" y="50" class="mutedsvg">Network</text></g>
      <g transform="translate(625 320)" class="systemGlow" id="sgSec" style="color:#36d399"><circle r="28" fill="#08251c" stroke="#36d399"/><text text-anchor="middle" y="5" font-size="24">🔒</text><text text-anchor="middle" y="50" class="mutedsvg">Security</text></g>
    </svg></div>
    <div class="panel"><h2>Learner action</h2><div class="controls"><button class="btn primary" onclick="sendPhoto()">📤 Send Photo</button><button class="btn" onclick="resetSend()">Reset</button></div><div class="kpis"><div class="kpi blue"><div class="label">Request</div><div class="value" id="req">Ready</div></div><div class="kpi ok"><div class="label">Systems</div><div class="value" id="sys">Idle</div></div><div class="kpi blue"><div class="label">Latency</div><div class="value" id="lat">--</div></div><div class="kpi ok"><div class="label">Result</div><div class="value" id="res">--</div></div></div><div class="note" id="sendNote"><b>Teaching point:</b><br/>A familiar digital action depends on real facilities, equipment, and people working together.</div></div>
  </section>

  <section id="day" class="view grid" style="display:none">
    <div class="panel"><h2>Your Digital Day</h2><p>Click an everyday activity. The SVG shows the hidden connection back to the data centre.</p><svg class="scene" viewBox="0 0 900 430"><g transform="translate(375 135)"><rect x="0" y="0" width="150" height="130" rx="12" fill="#132b48" stroke="#22d3ee" stroke-width="3"/><text x="75" y="55" text-anchor="middle" class="labelsvg">DATA</text><text x="75" y="78" text-anchor="middle" class="labelsvg">CENTRE</text><text x="75" y="105" text-anchor="middle" class="mutedsvg">hidden infrastructure</text></g><g id="dayLines"></g><g id="dayNodes"></g></svg></div>
    <div class="panel"><h2>Reveal what was working</h2><div class="dayGrid" id="dayButtons"></div><div class="note" id="dayNote"><b>Choose one:</b><br/>Messaging, streaming, banking, healthcare, AI, or maps.</div></div>
  </section>

  <section id="tour" class="view grid" style="display:none">
    <div class="panel"><h2>Explore the Data Centre</h2><p>Use this as the main SVG hotspot activity: learners click spaces on the floor plan and see what each area does.</p><svg class="scene" viewBox="0 0 900 430"><rect x="55" y="55" width="790" height="320" rx="18" fill="#07111f" stroke="#2c5b7d" stroke-width="4"/><g id="rooms"></g><path d="M120,335 C250,310 280,150 410,160 S630,260 760,105" stroke="#22d3ee" stroke-width="4" stroke-dasharray="8 12" fill="none"><animate attributeName="stroke-dashoffset" from="0" to="-40" dur="1.4s" repeatCount="indefinite"/></path><text x="450" y="405" text-anchor="middle" class="mutedsvg">Visitor route: security → logistics → server hall → power/cooling/network → operations</text></svg></div>
    <div class="panel"><h2 id="roomTitle">Select a hotspot</h2><div class="note" id="roomNote">Click a room in the floor plan to reveal its role and why it matters.</div></div>
  </section>

  <section id="systems" class="view grid" style="display:none">
    <div class="panel"><h2>Four Systems, One Goal</h2><p>A compact SVG for the reading: power, cooling, IT, and physical security all support reliable services.</p><svg class="scene" viewBox="0 0 900 430"><g transform="translate(375 145)"><rect x="0" y="0" width="150" height="155" rx="12" fill="#08172a" stroke="#22d3ee" stroke-width="3"/><text x="75" y="35" text-anchor="middle" class="labelsvg">SERVER</text><text x="75" y="58" text-anchor="middle" class="labelsvg">RACK</text><rect x="35" y="78" width="80" height="12" fill="#17395f"/><rect x="35" y="98" width="80" height="12" fill="#17395f"/><rect x="35" y="118" width="80" height="12" fill="#17395f"/></g><g id="systemArrows"></g><g onclick="stressTest()" class="hotspot"><rect x="345" y="365" width="210" height="42" rx="18" fill="#0e7490" stroke="#22d3ee"/><text x="450" y="392" text-anchor="middle" class="labelsvg">Run mini stress test</text></g></svg></div>
    <div class="panel"><h2>Incident-style learning</h2><div class="kpis"><div class="kpi blue"><div class="label">Power</div><div class="value" id="sPower">OK</div></div><div class="kpi ok"><div class="label">Cooling</div><div class="value" id="sCool">OK</div></div><div class="kpi blue"><div class="label">IT Load</div><div class="value" id="sIT">68%</div></div><div class="kpi ok"><div class="label">Alert</div><div class="value" id="sAlert">None</div></div></div><div class="note" id="sysNote"><b>Click the stress test.</b><br/>A small change in one system creates visible effects elsewhere.</div></div>
  </section>
  <div class="footer">Built as a single-file HTML/SVG/JavaScript PoC for embedding in Coursera via External Webpage iframe.</div>
</div>
<script>
function showView(id,btn){document.querySelectorAll('.view').forEach(v=>v.style.display='none');document.getElementById(id).style.display='grid';document.querySelectorAll('.tab').forEach(t=>t.classList.remove('active'));btn.classList.add('active')}
const packet=document.getElementById('packet'), path=document.getElementById('journeyPath');let anim=null;
function resetSend(){if(anim)anim.cancel();packet.style.opacity=0;['sgPower','sgCool','sgNet','sgSec'].forEach(id=>document.getElementById(id).classList.remove('on','pulse'));req.textContent='Ready';sys.textContent='Idle';lat.textContent='--';res.textContent='--';sendNote.innerHTML='<b>Teaching point:</b><br/>A familiar digital action depends on real facilities, equipment, and people working together.'}
function sendPhoto(){resetSend();packet.style.opacity=1;req.textContent='Photo';sys.textContent='Active';lat.textContent='0.8s';res.textContent='Sending';const len=path.getTotalLength();anim=packet.animate([{offsetDistance:'0%'},{offsetDistance:'100%'}],{duration:2600,fill:'forwards',easing:'ease-in-out'});packet.style.offsetPath='path("'+path.getAttribute('d')+'")';setTimeout(()=>sgNet.classList.add('on','pulse'),400);setTimeout(()=>sgPower.classList.add('on','pulse'),900);setTimeout(()=>sgCool.classList.add('on','pulse'),1300);setTimeout(()=>sgSec.classList.add('on','pulse'),1700);setTimeout(()=>{res.textContent='Delivered';sendNote.innerHTML='<b>What learners see:</b><br/>The message feels instant, but the action travels through networks to physical infrastructure supported by power, cooling, network, security, and operations.'},2600)}
const activities=[['💬','Message / video call','Servers carry words and video between people, often in under a second.'],['🎬','Streaming / gaming','Content is pulled from data centres and delivered on demand.'],['💳','Banking / shopping','Transactions are recorded and confirmed on protected equipment.'],['🏥','Health / learning','Online tools rely on facilities that must stay available.'],['🤖','AI / cloud backup','Answers are computed and files are stored in data centres.'],['🗺️','Maps / navigation','Live data is matched and returned to your screen in real time.']];
function buildDay(){const nodes=document.getElementById('dayNodes'),lines=document.getElementById('dayLines'),buttons=document.getElementById('dayButtons');const pts=[[130,90],[755,90],[125,215],[765,215],[165,340],[725,340]];activities.forEach((a,i)=>{const [x,y]=pts[i];lines.innerHTML+=`<path id="line${i}" d="M${x},${y} C${x<450?300:600},${y}  ${x<450?310:590},205 450,200" stroke="#274b68" stroke-width="4" fill="none"/>`;nodes.innerHTML+=`<g class="hotspot" onclick="selectDay(${i})"><circle id="node${i}" cx="${x}" cy="${y}" r="48" fill="#102947" stroke="#2c5b7d" stroke-width="3"/><text x="${x}" y="${y+5}" text-anchor="middle" font-size="27">${a[0]}</text><text x="${x}" y="${y+72}" text-anchor="middle" class="mutedsvg">${a[1]}</text></g>`;buttons.innerHTML+=`<div class="day" onclick="selectDay(${i})"><b>${a[0]} ${a[1]}</b><span>Reveal hidden infrastructure</span></div>`})}
function selectDay(i){document.querySelectorAll('.day').forEach((d,j)=>d.classList.toggle('active',i===j));for(let j=0;j<activities.length;j++){document.getElementById('node'+j).setAttribute('stroke',j===i?'#22d3ee':'#2c5b7d');document.getElementById('line'+j).setAttribute('stroke',j===i?'#22d3ee':'#274b68');document.getElementById('line'+j).setAttribute('stroke-dasharray',j===i?'8 10':'0')}dayNote.innerHTML=`<b>${activities[i][1]}</b><br/>${activities[i][2]}`}
buildDay();
const roomsData=[['Reception',95,85,165,80,'Every visit begins with identity checks and approved access.'],['Logistics',95,215,165,95,'New equipment arrives, is scanned, tracked, and prepared before moving deeper inside.'],['Server Hall',330,115,240,160,'The heart of the facility: servers store data, process requests, and run services.'],['Power',625,85,180,75,'Electrical systems feed the equipment and provide backup support.'],['Cooling',625,175,180,75,'Cooling removes heat so equipment stays within safe operating conditions.'],['Network',625,265,180,75,'Network equipment connects the data centre to users and other locations.'],['Operations',330,300,240,55,'Teams monitor alerts across power, cooling, network, and security.']];
function buildRooms(){const g=document.getElementById('rooms');roomsData.forEach((r,i)=>{g.innerHTML+=`<g class="hotspot" onclick="selectRoom(${i})"><rect id="room${i}" class="room" x="${r[1]}" y="${r[2]}" width="${r[3]}" height="${r[4]}" rx="12"/><text x="${r[1]+r[3]/2}" y="${r[2]+r[4]/2+5}" text-anchor="middle" class="labelsvg">${r[0]}</text></g>`})}
function selectRoom(i){roomsData.forEach((r,j)=>document.getElementById('room'+j).classList.toggle('active',i===j));roomTitle.textContent=roomsData[i][0];roomNote.innerHTML='<b>What happens here:</b><br/>'+roomsData[i][5]+'<br><br><b>Connection:</b><br/>This area supports the same goal: reliable digital services.'}
buildRooms();
function buildSystems(){const g=document.getElementById('systemArrows');const items=[['⚡ Power',170,95,'#fbbf24'],['❄ Cooling',450,55,'#60a5fa'],['🌐 IT / Network',730,95,'#22d3ee'],['🔒 Security',450,335,'#36d399']];items.forEach((it,i)=>{const [name,x,y,c]=it;g.innerHTML+=`<g id="sysIcon${i}" style="color:${c}"><line x1="${x}" y1="${y}" x2="450" y2="220" stroke="${c}" stroke-width="4" stroke-dasharray="9 10"><animate attributeName="stroke-dashoffset" from="0" to="-38" dur="1.2s" repeatCount="indefinite"/></line><circle cx="${x}" cy="${y}" r="45" fill="#102947" stroke="${c}" stroke-width="3"/><text x="${x}" y="${y+5}" text-anchor="middle" class="labelsvg">${name}</text></g>`})}
function stressTest(){sCool.textContent='WARN';sCool.parentElement.className='kpi warn';sIT.textContent='82%';sAlert.textContent='Temp';sAlert.parentElement.className='kpi warn';sysNote.innerHTML='<b>Incident:</b><br/>Cooling weakens. Server temperature rises. Operations sees an alert before the user notices a service problem.';document.getElementById('sysIcon1').classList.add('pulse')}
buildSystems();
</script>
</body>
</html>
